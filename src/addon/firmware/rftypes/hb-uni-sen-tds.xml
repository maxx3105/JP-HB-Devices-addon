<?xml version="1.0" encoding="iso-8859-1"?>
<device version="2" cyclic_timeout="7200">
  <supported_types>
    <type name="HB-UNI-Sen-TDS" id="HB-UNI-Sen-TDS">
      <parameter index="10.0" size="2.0" const_value="0xFC30" />
    </type>
  </supported_types>

  <paramset type="MASTER" id="hm_uni_sen_tds_dev_master">
    <parameter id="HB_MEASURE_INTERVAL">
      <logical type="integer" min="5" max="3600" unit="s" default="10" />
      <physical type="integer" interface="config" list="0" index="31.0" size="2" />
    </parameter>
    <parameter id="HBWEA_TRANSMIT_INTERVAL">
      <logical type="integer" min="1" max="255" unit="Messungen" default="18" />
      <physical type="integer" interface="config" list="0" index="33.0" size="1" />
    </parameter>
    <parameter id="BACKLIGHT_ON_TIME">
      <logical type="integer" min="0" max="255" default="10" unit="s"/>
      <physical type="integer" interface="config" list="0" index="14.0" size="1.0"/>
    </parameter>
  </paramset>

  <channels>

    <!-- ============================================================
         KANAL 0 – MAINTENANCE (intern)
         ============================================================ -->
    <channel index="0" type="MAINTENANCE" ui_flags="internal" class="maintenance" count="1">
      <paramset type="MASTER" id="maint_ch_master" />
      <paramset type="VALUES" id="maint_ch_values">
        <parameter id="UNREACH" operations="read,event" ui_flags="service">
          <logical type="boolean" />
          <physical type="integer" interface="internal" value_id="UNREACH" />
        </parameter>
        <parameter id="STICKY_UNREACH" operations="read,write,event" ui_flags="service,sticky">
          <logical type="boolean" />
          <physical type="integer" interface="internal" value_id="STICKY_UNREACH" />
        </parameter>
        <parameter id="CONFIG_PENDING" operations="read,event" ui_flags="service">
          <logical type="boolean" />
          <physical type="integer" interface="internal" value_id="CONFIG_PENDING" />
        </parameter>
        <parameter id="RSSI_DEVICE" operations="read,event">
          <logical type="integer" />
          <physical type="integer" interface="internal" value_id="RSSI_DEVICE" />
        </parameter>
        <parameter id="RSSI_PEER" operations="read,event">
          <logical type="integer" />
          <physical type="integer" interface="internal" value_id="RSSI_PEER" />
        </parameter>
        <parameter id="DEVICE_IN_BOOTLOADER" operations="read,event" ui_flags="service">
          <logical type="boolean" />
          <physical type="integer" interface="internal" value_id="DEVICE_IN_BOOTLOADER" />
        </parameter>
        <parameter id="UPDATE_PENDING" operations="read,event" ui_flags="service">
          <logical type="boolean" />
          <physical type="integer" interface="internal" value_id="UPDATE_PENDING" />
        </parameter>
      </paramset>
    </channel>

    <!-- ============================================================
         KANAL 1 – HB_GENERIC
         Messwerte: Temperatur (DS18B20), TDS (ppm)
         Konfigurationsregister Liste 1:
           Byte 5: TEMPERATURE_OFFSET
         ============================================================ -->
    <channel autoregister="true" index="1" type="HB_GENERIC" count="1">
      <paramset type="MASTER" id="HB-UNI-Sen-TDS_master">
        <parameter id="TEMPERATURE_OFFSET">
          <logical type="option">
            <option id="-3.5K" /><option id="-3.0K" /><option id="-2.5K" />
            <option id="-2.0K" /><option id="-1.5K" /><option id="-1.0K" />
            <option id="-0.5K" /><option id="0.0K" default="true" />
            <option id="0.5K"  /><option id="1.0K"  /><option id="1.5K"  />
            <option id="2.0K"  /><option id="2.5K"  /><option id="3.0K"  />
            <option id="3.5K"  />
          </logical>
          <physical type="integer" interface="config" list="1" index="5.0" size="1.0" />
        </parameter>
      </paramset>
      <paramset type="VALUES" id="HB-UNI-Sen-TDS_values">
        <parameter id="TEMPERATURE" operations="read,event">
          <logical type="float" min="-40.0" max="80.0" unit="&#176;C" />
          <physical type="integer" interface="command" value_id="TEMPERATURE">
            <event frame="MEASURE_EVENT" />
          </physical>
          <conversion type="float_integer_scale" factor="10.0" />
        </parameter>
        <parameter id="HB_TDS" operations="read,event" control="NONE">
          <logical type="float" min="0.0" max="9999.9" unit="ppm"/>
          <physical type="integer" interface="command" value_id="HB_TDS" no_init="true">
            <event frame="MEASURE_EVENT"/>
          </physical>
          <conversion type="float_integer_scale" factor="10"/>
        </parameter>
        <parameter id="INFO_MSG" operations="read,event" ui_flags="service" control="NONE">
          <logical type="option">
            <option id="HB_OPERATION_NORMAL"      index="0" default="true"/>
            <option id="HB_OPERATION_CALIBRATION" index="1"/>
          </logical>
          <physical type="integer" interface="command" value_id="INFO_MSG">
            <event frame="INFO_MSG_EVENT"/>
          </physical>
        </parameter>
      </paramset>
      <paramset type="LINK" id="HB-UNI-Sen-TDS_link" />
    </channel>

  </channels>

  <!-- ============================================================
       FRAMES
       Byte-Layout des BidCoS-Telegramms (type=0x53):
         Byte  9    : Kanal (fixed_channel=1)
         Byte  9-10 : TEMPERATURE (signed, /10 degC)
         Byte 11-12 : HB_TDS (/10 ppm)
       ============================================================ -->
  <frames>

    <frame id="MEASURE_EVENT" direction="from_device" event="true"
           fixed_channel="1" type="0x53">
      <parameter type="integer" signed="true" index="9.0" size="1.7" param="TEMPERATURE" />
      <parameter type="integer"               index="11.0" size="2.0" param="HB_TDS" />
    </frame>

    <frame id="INFO_MSG_EVENT" direction="from_device"
           allowed_receivers="BROADCAST,CENTRAL,OTHER" event="true"
           type="0x10" subtype="6" subtype_index="9" fixed_channel="1">
      <parameter type="integer" index="12.1" size="0.3" param="INFO_MSG"/>
    </frame>

  </frames>

  <paramset_defs></paramset_defs>

</device>
